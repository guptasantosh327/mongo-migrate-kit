{
  "name": "mongo-migrate-kit",
  "version": "0.1.0",
  "description": "Production-grade MongoDB migration toolkit for Node.js",
  "license": "MIT",
  "author": "guptasantosh327@gmail.com",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mmk": "./dist/mmk.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "release": "bumpp && npm publish"
  },
  "keywords": [
    "mongodb",
    "migration",
    "migrations",
    "mongoose",
    "database",
    "cli",
    "typescript"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "ora": "^5.4.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "mongodb": ">=5.0.0",
    "mongoose": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^2.1.8",
    "bumpp": "^9.9.0",
    "changelogen": "^0.5.7",
    "mongodb": "^6.12.0",
    "mongodb-memory-server": "^10.1.2",
    "mongoose": "^8.9.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
